{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "${configDir}",
    "preserveSymlinks": false,
    "paths": {
      "@repro/component-library": ["./packages/component-library/src/*"]
    },
    "types": [
      "node"
    ]
  }
}
